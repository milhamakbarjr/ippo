# =============================================================================
# Ippo — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Neon Postgres)
# Get from: https://console.neon.tech → your project → Connection string
# Use the "pooled" connection string for production, "direct" for migrations.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Used by drizzle-kit for migrations (direct connection, not pooled)
DATABASE_URL_DIRECT=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# AUTH (Better Auth)
# BETTER_AUTH_SECRET: random string, min 32 chars.
# Generate with: openssl rand -base64 32
# BETTER_AUTH_URL: full base URL of your app (no trailing slash)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=your-random-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# Get from: https://resend.com → API Keys
# Use a test key (re_test_...) for development — no real emails sent.
# Verify your sending domain (ippo.jp) in Resend before production.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address — must match your verified Resend domain
RESEND_FROM_EMAIL=noreply@ippo.jp
RESEND_REPLY_TO=support@ippo.jp

# -----------------------------------------------------------------------------
# APP
# Public base URL — used for OTP email links and auth callbacks.
# VITE_ prefix = exposed to browser (safe for public values only).
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# ENVIRONMENT
# "development" | "staging" | "production"
# -----------------------------------------------------------------------------
NODE_ENV=development
