{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ippo",
  "compatibility_date": "2026-04-16",
  "compatibility_flags": [
    "nodejs_compat",
    "nodejs_compat_populate_process_env"
  ],
  "main": "@tanstack/react-start/server-entry",
  "observability": {
    "enabled": true
  },
  "vars": {
    "NODE_ENV": "production",
    "VITE_APP_URL": "https://ippo.milhamakbarjr.workers.dev"
  }
}
